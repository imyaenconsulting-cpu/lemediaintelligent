{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/media.html", "dest": "/media.html" },
    { "src": "/skylens.html", "dest": "/skylens.html" },
    { "src": "/guide.html", "dest": "/guide.html" },
    { "src": "/guide_deploy.html", "dest": "/guide_deploy.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
