# ═══════════════════════════════════════════════════════════════════
# FICHIER .env.example — Le Média Intelligent + SkyLens
# ═══════════════════════════════════════════════════════════════════
# NE JAMAIS mettre ce fichier avec de vraies clés sur GitHub !
# Copiez ces variables dans Vercel > Settings > Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ── ANTHROPIC (Claude AI) ──────────────────────────────────────────
# Obtenez votre clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-VOTRE-CLE-ICI

# ── SUPABASE ───────────────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase > Settings > API
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...VOTRE-CLE-ANON
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...VOTRE-CLE-SERVICE-ROLE

# ── STRIPE (paiements) ────────────────────────────────────────────
# Trouvez ces valeurs dans : Stripe > Developers > API Keys
STRIPE_PUBLIC_KEY=pk_live_VOTRE-CLE-PUBLIQUE
STRIPE_SECRET_KEY=sk_live_VOTRE-CLE-SECRETE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE-SECRET-WEBHOOK

# IDs des produits Stripe (créez-les dans Stripe > Products)
STRIPE_PRICE_PREMIUM=price_VOTRE-ID-PREMIUM-MENSUEL
STRIPE_PRICE_PRO=price_VOTRE-ID-PRO-MENSUEL
STRIPE_PRICE_SKYLENS=price_VOTRE-ID-SKYLENS

# ── OPENSKY NETWORK (données avions) ─────────────────────────────
# Créez un compte sur : https://opensky-network.org
OPENSKY_USERNAME=votre-username-opensky
OPENSKY_PASSWORD=votre-mot-de-passe-opensky

# ── RESEND (emails + newsletters) ────────────────────────────────
# Créez un compte sur : https://resend.com
RESEND_API_KEY=re_VOTRE-CLE-RESEND
RESEND_FROM_EMAIL=no-reply@lemediaintelligent.com

# ── ADMIN ─────────────────────────────────────────────────────────
# Votre adresse Gmail personnelle — accès admin exclusif
ADMIN_EMAIL=votre-email@gmail.com

# ── APP ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://lemediaintelligent.com
NODE_ENV=production

# ── SENTINEL HUB (images satellite) ─────────────────────────────
# Optionnel - Créez un compte sur : https://www.sentinel-hub.com
SENTINEL_HUB_CLIENT_ID=VOTRE-CLIENT-ID
SENTINEL_HUB_CLIENT_SECRET=VOTRE-SECRET

# ── GOOGLE OAUTH ─────────────────────────────────────────────────
# Configuré automatiquement via Supabase Auth
# Mais notez vos credentials Google Cloud ici pour référence
GOOGLE_CLIENT_ID=VOTRE-ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=VOTRE-SECRET-GOOGLE
